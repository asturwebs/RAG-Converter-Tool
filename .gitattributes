# Auto detect text files and perform LF normalization
* text=auto

# PowerShell scripts always use CRLF on Windows (required for execution)
*.ps1 text eol=crlf
*.psm1 text eol=crlf

# Shell scripts always use LF
*.sh text eol=lf

# Markdown and config files
*.md text
*.yaml text
*.yml text
*.json text
*.cff text
*.txt text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
